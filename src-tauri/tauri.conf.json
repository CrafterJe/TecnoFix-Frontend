{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TecnoFix",
  "version": "0.1.15",
  "identifier": "com.tecnofix.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TecnoFix",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "bannerPath": "wix/banner.bmp",
        "dialogImagePath": "wix/dialog.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "untrusted comment: minisign public key: 1613C8A6FEBF4BEC\nRWTsS7/+psgTFiPWV7NWSKSRaoxq6s/RIIehkOla7N38O3SUuxWY7M/A",
      "endpoints": [
        "https://github.com/CrafterJe/TecnoFix-Frontend/releases/latest/download/latest.json"
      ]
    }
  }
}